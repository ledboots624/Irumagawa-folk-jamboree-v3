    <mxCell id="4" value="〜たった一人から始まった14年間・全100回の草の根フェス〜" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#E6F3FF;fontSize=16;" vertex="1" parent="1">
