    <mxCell id="3" value="入間川フォークジャンボリーの軌跡" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#FFFFFF;fontSize=28;fontStyle=1;" vertex="1" parent="1">
