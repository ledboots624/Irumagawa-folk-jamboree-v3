    <!-- 1994 -->
    <mxCell id="24" value="1994年" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#10739E;fontColor=#FFFFFF;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="70" y="640" width="60" height="60" as="geometry" />
    </mxCell>
    <mxCell id="25" value="【黎明期】孤独なスタート" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="640" width="250" height="30" as="geometry" />
    </mxCell>
    <mxCell id="26" value="入間市「新しきを知る公園」にて開始。当初は出演者＝松しょう氏のみ。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="150" y="670" width="600" height="40" as="geometry" />
    </mxCell>

    <!-- Expansion -->
    <mxCell id="27" value="拡大期" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#5EA458;fontColor=#FFFFFF;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="75" y="730" width="50" height="50" as="geometry" />
    </mxCell>
    <mxCell id="28" value="【発展期】地域への定着" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="730" width="250" height="30" as="geometry" />
    </mxCell>
    <mxCell id="29" value="口コミで出演者が増加。中津川フォークジャンボリーの精神を継承しつつ、過激な政治性よりも「生活の中の音楽」を重視する独自のスタイルを確立。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="150" y="760" width="600" height="40" as="geometry" />
    </mxCell>

    <!-- 2008 -->
    <mxCell id="30" value="2008年" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#F29F05;fontColor=#FFFFFF;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="70" y="820" width="60" height="60" as="geometry" />
    </mxCell>
    <mxCell id="31" value="【完結】第100回で幕" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="820" width="250" height="30" as="geometry" />
    </mxCell>
    <mxCell id="32" value="14年の歴史に一区切り。第100回記念開催をもって「入間川フォークジャンボリー」としては終了。しかしコミュニティは解散せず。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="150" y="850" width="600" height="40" as="geometry" />
    </mxCell>

    <!-- Future -->
    <mxCell id="33" value="現在" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#666666;fontColor=#FFFFFF;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="75" y="910" width="50" height="50" as="geometry" />
    </mxCell>
    <mxCell id="34" value="【継承】入間サウンドヘヴンへ" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="150" y="910" width="250" height="30" as="geometry" />
    </mxCell>
    <mxCell id="35" value="後継イベント「入間サウンドヘヴン」へと精神が引き継がれる。&#10;2026年3月にも松しょう氏のライブが予定されており、活動は現在進行形。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="150" y="940" width="600" height="40" as="geometry" />
    </mxCell>

    <!-- Conclusion Section -->
    <mxCell id="36" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=none;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="1020" width="740" height="110" as="geometry" />
    </mxCell>
    <mxCell id="37" value="結論：地域文化資産としての価値" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#F29F05;fontSize=18;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="40" y="1030" width="740" height="30" as="geometry" />
    </mxCell>
    <mxCell id="38" value="入間川フォークジャンボリーは、1970年代の政治的な「祭りの季節」の精神を受け継ぎながらも、&#10;それを「日常のコミュニティ」へと昇華させた稀有な事例である。&#10;14年間継続したという事実は、一人の情熱が地域文化を変えうることを証明している。" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontColor=#FFFFFF;fontSize=13;spacing=5;" vertex="1" parent="1">
      <mxGeometry x="60" y="1065" width="700" height="50" as="geometry" />
    </mxCell>

  </root>
