    <mxCell id="15" value="1人" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=32;fontStyle=1;fontColor=#5EA458;" vertex="1" parent="1">
      <mxGeometry x="580" y="210" width="160" height="40" as="geometry" />
    </mxCell>
    <mxCell id="16" value="松しょう氏の単独ライブから" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="580" y="250" width="160" height="20" as="geometry" />
    </mxCell>

    <!-- Section 2: Founder -->
    <mxCell id="17" value="発起人：松しょう氏の哲学" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#81D4FA;fontStyle=1;fontSize=16;align=left;spacingLeft=20;" vertex="1" parent="1">
      <mxGeometry x="40" y="340" width="740" height="40" as="geometry" />
    </mxCell>
    
    <mxCell id="18" value="「場所を作る」ことへの執念" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#10739E;strokeWidth=2;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="40" y="400" width="220" height="60" as="geometry" />
    </mxCell>
    
    <mxCell id="19" value="1994年2月、誰もいない入間市「新しきを知る公園」で、たった一人の「観客兼演者」として歌い始めたのが全ての始まり。&#10;既存のホールではなく、公共空間を「音楽の場」に変える試み。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DDDDDD;align=left;verticalAlign=top;spacing=10;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="280" y="400" width="500" height="60" as="geometry" />
    </mxCell>

    <mxCell id="20" value="コミュニティ・ビルダー" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#F29F05;strokeWidth=2;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
      <mxGeometry x="40" y="480" width="220" height="60" as="geometry" />
    </mxCell>
    
    <mxCell id="21" value="カリスマ的指導者ではなく、自らが楽しむ姿を見せることで周囲を巻き込むスタイル。&#10;「松仲良（まつなかよし）」という別名の通り、人と人をつなぐ触媒として機能した。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#DDDDDD;align=left;verticalAlign=top;spacing=10;whiteSpace=wrap;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="280" y="480" width="500" height="60" as="geometry" />
    </mxCell>

    <!-- Section 3: History Flow -->
    <mxCell id="22" value="イベントの歴史的変遷" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FFCC80;fontStyle=1;fontSize=16;align=left;spacingLeft=20;" vertex="1" parent="1">
      <mxGeometry x="40" y="580" width="740" height="40" as="geometry" />
    </mxCell>

    <!-- Arrow -->
    <mxCell id="23" value="" style="shape=flexArrow;endArrow=classic;html=1;fillColor=#CCCCCC;strokeColor=none;width=10;endSize=8.67;" edge="1" parent="1">
      <mxGeometry width="50" height="50" relative="1" as="geometry">
        <mxPoint x="100" y="650" as="sourcePoint" />
        <mxPoint x="100" y="920" as="targetPoint" />
